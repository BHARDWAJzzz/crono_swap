rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function to check if user is moderator or superadmin
    function isModerator() {
      return request.auth != null && 
        (firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['moderator', 'superadmin'] ||
         firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.email == 'superadmin@gmail.com');
    }

    // Profile images: Publicly readable, owner can write
    match /profile_images/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Verification documents: Only moderator or owner can read, owner can write
    match /verification/{userId}/{fileName} {
      allow read: if request.auth != null && (request.auth.uid == userId || isModerator());
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Lecture files: Authenticated users can read (for now), owner can write
    match /lectures/{sellerId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == sellerId;
    }
  }
}
