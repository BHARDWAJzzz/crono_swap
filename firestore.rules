rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is an approved moderator or superadmin
    function isModerator() {
      return request.auth != null && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['moderator', 'superadmin'] ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email == 'superadmin@gmail.com');
    }

    // User profiles
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (request.auth.uid == userId || isModerator());
    }
    
    // Skill offers
    match /skills/{skillId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || isModerator());
    }

    // Swap requests
    match /swaps/{swapId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.senderId || 
        request.auth.uid == resource.data.receiverId ||
        isModerator()
      );
      allow create: if request.auth != null && request.auth.uid == request.resource.data.senderId;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.senderId || 
        request.auth.uid == resource.data.receiverId ||
        isModerator()
      );
      allow delete: if isModerator();

      // Messages within swaps
      match /messages/{messageId} {
        allow read: if request.auth != null && (
          request.auth.uid in [get(/databases/$(database)/documents/swaps/$(swapId)).data.senderId, get(/databases/$(database)/documents/swaps/$(swapId)).data.receiverId] ||
          isModerator()
        );
        allow create: if request.auth != null && (
          request.auth.uid in [get(/databases/$(database)/documents/swaps/$(swapId)).data.senderId, get(/databases/$(database)/documents/swaps/$(swapId)).data.receiverId]
        );
      }
    }

    // Chats & Messages
    match /chats/{chatId} {
      allow read: if request.auth != null && (request.auth.uid in resource.data.participants || isModerator());
      allow write: if request.auth != null && (request.auth.uid in request.resource.data.participants || isModerator());
      
      match /messages/{messageId} {
        allow read: if request.auth != null && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants || isModerator());
        allow create: if request.auth != null && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);
      }
    }

    // Transactions (Ledger)
    match /transactions/{transactionId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || isModerator());
      allow create: if request.auth != null && (request.auth.uid == request.resource.data.userId || isModerator());
      allow update, delete: if false; // Transactions are immutable
    }

    // Lectures (Marketplace)
    match /lectures/{lectureId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (resource.data.providerId == request.auth.uid || isModerator());
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false; // Reviews are immutable
    }

    // App Configuration (Admin-only write, public read for app settings)
    match /app_config/{configId} {
      allow read: if request.auth != null;
      allow write: if isModerator();
    }

    // Donations (Community pool)
    match /donations/{donationId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false; // Donations are immutable
    }

    // Reports
    match /reports/{reportId} {
      allow read, update, delete: if isModerator();
      allow create: if request.auth != null;
    }
    
    // Notifications
    match /notifications/{notificationId} {
      allow read, update: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null; 
      allow delete: if request.auth != null && (request.auth.uid == resource.data.userId || isModerator());
    }

    // Quests (Bounty System)
    match /quests/{questId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.createdBy;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.createdBy || 
        request.auth.uid == resource.data.assignedTo ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['applicantIds'])
      );
      allow delete: if isModerator();
    }
  }
}
